# ------------------------------
# Frontend (Vite)
# ------------------------------
# Public backend API URL — used only in **production** builds (vite build).
# Leave unset for local `npm run dev`: the app calls `/api` and Vite proxies to PORT below.
# (A system-wide VITE_API_URL pointing at the wrong port breaks login in dev.)
VITE_API_URL=https://your-api.onrender.com

# ------------------------------
# Backend (Render Web Service)
# ------------------------------
PORT=3001
# Local: start API + Vite together (Vite proxies /api to PORT): npm run dev:all
# With API already running, check GET /api/users exists: npm run test:api-users
JWT_SECRET=change-this-to-a-long-random-secret

# CORS allowlist (comma-separated for multiple domains)
CORS_ORIGIN=https://your-frontend.onrender.com
# FRONTEND_URL can be used as fallback if CORS_ORIGIN is not set.
FRONTEND_URL=https://your-frontend.onrender.com

# ------------------------------
# Database (External - recommended for Render)
# ------------------------------
# Use MongoDB Atlas (recommended).
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=inventory_system
MONGODB_COLLECTION=app_state

# If false, local file persistence is disabled (recommended in production).
USE_LOCAL_DATA_FILE=false

# ------------------------------
# SMTP / Alert emails
# ------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-mailbox@example.com
SMTP_PASS=your-password-or-app-password
SMTP_FROM=your-mailbox@example.com

ALERT_MAIL_TO_MANAGER=manager@example.com
ALERT_MAIL_TO_PROCUREMENT=procurement@example.com

# Stock alert digest email: one automatic send per calendar day (server local time) when alerts exist.
# Use 24h clock, e.g. 08:00 or 14:30
STOCK_ALERT_MAIL_DAILY_AT=08:00
